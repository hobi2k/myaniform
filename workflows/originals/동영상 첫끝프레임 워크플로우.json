: \n\nWan_2_2_I2V_A14B_HIGH_lightx2v_MoE_distill_lora_rank_64_bf_16.safetensors\n\n### For FP8 on Low: \n\nlightx2v_I2V_14B_480p_cfg_step_distill_rank128_bf16.safetensors\n\n### Speed LoRAs for GGUF on High:\n Wan21_I2V_14B_lightx2v_cfg_step_distill_lora_rank64.safetensors\n\n### For GGUF on Low:\n\nWan21_I2V_14B_lightx2v_cfg_step_distill_lora_rank64.safetensors"],"color":"#322","bgcolor":"#533"},{"id":173,"type":"Any Switch (rgthree)","pos":[-125.24654388427734,359.4276123046875],"size":[250.04998779296875,106],"flags":{"collapsed":true},"order":22,"mode":0,"inputs":[{"dir":3,"name":"any_01","type":"CLIP","link":327},{"dir":3,"name":"any_02","type":"CLIP","link":330},{"dir":3,"name":"any_03","type":"CLIP","link":null},{"dir":3,"name":"any_04","type":"CLIP","link":null},{"name":"any_05","type":"CLIP","link":null}],"outputs":[{"dir":4,"label":"CLIP","localized_name":"*","name":"*","type":"*","links":[328,329]}],"properties":{"cnr_id":"rgthree-comfy","ver":"26988df02c7e84d0fe22908ad0955fc8797796f6","Node name for S&R":"Any Switch (rgthree)","ue_properties":{"version":"7.0.1","widget_ue_connectable":{}}},"widgets_values":[]},{"id":174,"type":"MarkdownNote","pos":[-1067.8333740234375,551.4628295898438],"size":[267.2347412109375,255.93576049804688],"flags":{},"order":6,"mode":0,"inputs":[],"outputs":[],"properties":{"ue_properties":{"version":"7.0.1","widget_ue_connectable":{}}},"widgets_values":["## Load CLIP or GGUF CLIP \n\nAlthough GGUF Models do work with standard Text Encoders, I've had good results using an actual GGUF Text Encoder. In my case I'm using the \n\numt5-xxl-ecoder-Q5_K_M.gguf\n\nSimply bypass (CTRL + B) the one you don't want to use, no need for manual rewiring."],"color":"#322","bgcolor":"#533"},{"id":163,"type":"MarkdownNote","pos":[-168.15200805664062,-399.80792236328125],"size":[260.3477783203125,159.51837158203125],"flags":{},"order":7,"mode":0,"inputs":[],"outputs":[],"properties":{"ue_properties":{"version":"7.0.1","widget_ue_connectable":{}}},"widgets_values":["## SmoothMix Wan 2.2, Enhanced NSFW Cam and other merges\n\n**do not need speed LoRAs**. \n\nDisable this node when using merges. When in doubt, check the documentation of the merge you're using."],"color":"#322","bgcolor":"#533"},{"id":169,"type":"Note","pos":[2645.2314453125,-458.5123596191406],"size":[581.6995849609375,211.47621154785156],"flags":{},"order":8,"mode":0,"inputs":[],"outputs":[],"title":"Temporary prompt box","properties":{"ue_properties":{"version":"7.0.1","widget_ue_connectable":{}}},"widgets_values":["Anime-style female character resembling Rosalina riding a sleek black futuristic sport motorcycle on a neon-lit racetrack at night. Full-body rider in teal racing suit and boots. High-speed motion, rear wheel spinning rapidly, subtle motion blur on track surface. Long blonde hair streaming backward with wind force. Bright stadium lights overhead, cool blue ambient lighting. Yellow-orange sparks and particle streaks emitted from rear wheel while cornering.\n\nDynamic tracking shot: camera starts low behind the motorcycle, slightly right offset. Smooth 180-degree orbital camera movement around the rider during the turn. Camera ends in a frontal medium shot of the rider on the bike. Character tilts forward in racing posture and briefly turns head to look directly at the camera. No camera shake. Continuous smooth motion. Cinematic lighting, high contrast, sharp focus on rider and bike."],"color":"#432","bgcolor":"#653"},{"id":86,"type":"CLIPLoader","pos":[-754.4541015625,552.8628540039062],"size":[270,106],"flags":{},"order":9,"mode":4,"inputs":[{"localized_name":"CLIP 파일명","name":"clip_name","type":"COMBO","widget":{"name":"clip_name"},"link":null},{"localized_name":"유형","name":"type","type":"COMBO","widget":{"name":"type"},"link":null},{"localized_name":"장치","name":"device","shape":7,"type":"COMBO","widget":{"name":"device"},"link":null}],"outputs":[{"localized_name":"CLIP","name":"CLIP","type":"CLIP","links":[330]}],"properties":{"