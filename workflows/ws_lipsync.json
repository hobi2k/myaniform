{
  "1": {
    "_meta": {"title": "Wan2.2 S2V 모델 (GGUF)"},
    "class_type": "UnetLoaderGGUF",
    "inputs": {
      "unet_name": "wan_s2v/Wan2.2-S2V-14B-Q4_K_M.gguf"
    }
  },
  "2": {
    "_meta": {"title": "WAN T5 CLIP"},
    "class_type": "CLIPLoader",
    "inputs": {
      "clip_name": "umt5_xxl_fp8_e4m3fn_scaled.safetensors",
      "type": "wan",
      "device": "default"
    }
  },
  "3": {
    "_meta": {"title": "WAN VAE"},
    "class_type": "VAELoader",
    "inputs": {
      "vae_name": "Wan2_1_VAE_bf16.safetensors"
    }
  },
  "4": {
    "_meta": {"title": "Audio Encoder (wav2vec2)"},
    "class_type": "AudioEncoderLoader",
    "inputs": {
      "audio_encoder_name": "wav2vec2_large_english_fp32.safetensors"
    }
  },
  "5": {
    "_meta": {"title": "씬 키프레임 로드"},
    "class_type": "LoadImage",
    "inputs": {
      "image": "keyframe.png"
    }
  },
  "6": {
    "_meta": {"title": "음성 로드"},
    "class_type": "LoadAudio",
    "inputs": {
      "audio": "voice.flac"
    }
  },
  "7": {
    "_meta": {"title": "Audio 인코딩"},
    "class_type": "AudioEncoderEncode",
    "inputs": {
      "audio_encoder": ["4", 0],
      "audio": ["6", 0]
    }
  },
  "8": {
    "_meta": {"title": "씬 Positive"},
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["2", 0],
      "text": "anime style, talking character, natural expression, soft lighting"
    }
  },
  "9": {
    "_meta": {"title": "Negative"},
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["2", 0],
      "text": "worst quality, low quality, static, blurry, extra limbs"
    }
  },
  "10": {
    "_meta": {"title": "Wan S2V 준비"},
    "class_type": "WanSoundImageToVideo",
    "inputs": {
      "positive": ["8", 0],
      "negative": ["9", 0],
      "vae": ["3", 0],
      "width": 832,
      "height": 1216,
      "length": 81,
      "batch_size": 1,
      "audio_encoder_output": ["7", 0],
      "ref_image": ["5", 0]
    }
  },
  "11": {
    "_meta": {"title": "KSampler"},
    "class_type": "KSamplerAdvanced",
    "inputs": {
      "model": ["1", 0],
      "positive": ["10", 0],
      "negative": ["10", 1],
      "latent_image": ["10", 2],
      "add_noise": "enable",
      "noise_seed": 0,
      "steps": 20,
      "cfg": 5.0,
      "sampler_name": "euler",
      "scheduler": "simple",
      "start_at_step": 0,
      "end_at_step": 10000,
      "return_with_leftover_noise": "disable"
    }
  },
  "12": {
    "_meta": {"title": "VAE Decode"},
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["11", 0],
      "vae": ["3", 0]
    }
  },
  "13": {
    "_meta": {"title": "MMAudio 모델"},
    "class_type": "MMAudioModelLoader",
    "inputs": {
      "mmaudio_model": "mmaudio_large_44k_v2_fp16.safetensors",
      "base_precision": "fp16"
    }
  },
  "14": {
    "_meta": {"title": "MMAudio Feature Utils"},
    "class_type": "MMAudioFeatureUtilsLoader",
    "inputs": {
      "vae_model": "mmaudio_vae_44k_fp16.safetensors",
      "synchformer_model": "mmaudio_synchformer_fp16.safetensors",
      "clip_model": "apple_DFN5B-CLIP-ViT-H-14-384_fp16.safetensors",
      "mode": "44k",
      "precision": "fp16"
    }
  },
  "15": {
    "_meta": {"title": "SFX 생성"},
    "class_type": "MMAudioSampler",
    "inputs": {
      "mmaudio_model": ["13", 0],
      "feature_utils": ["14", 0],
      "images": ["12", 0],
      "duration": 3.5,
      "steps": 25,
      "cfg": 4.5,
      "seed": 0,
      "prompt": "ambient indoor sounds, subtle background",
      "negative_prompt": "music, speech",
      "mask_away_clip": false,
      "force_offload": true
    }
  },
  "16": {
    "_meta": {"title": "대사 + SFX 믹스"},
    "class_type": "GeekyAudioMixer",
    "inputs": {
      "audio_1": ["6", 0],
      "audio_2": ["15", 0],
      "output_duration": 10.0,
      "output_format": "wav",
      "sample_rate": 44100,
      "audio_1_volume": 1.0,
      "audio_1_start_time": 0.0,
      "audio_1_fade_in": 0.0,
      "audio_1_fade_out": 0.0,
      "audio_2_volume": 0.35,
      "audio_2_start_time": 0.0,
      "audio_2_fade_in": 0.1,
      "audio_2_fade_out": 0.2
    }
  },
  "50": {
    "_meta": {"title": "ColorMatch (키프레임 기준)"},
    "class_type": "ColorMatch",
    "inputs": {
      "image_ref": ["5", 0],
      "image_target": ["12", 0],
      "method": "mkl",
      "strength": 0.5
    }
  },
  "51": {
    "_meta": {"title": "RIFE 보간 (16→32fps)"},
    "class_type": "RIFE VFI",
    "inputs": {
      "ckpt_name": "rife49.pth",
      "frames": ["50", 0],
      "clear_cache_after_n_frames": 10,
      "multiplier": 2,
      "fast_mode": true,
      "ensemble": true,
      "scale_factor": 1.0,
      "dtype": "float32",
      "torch_compile": false,
      "batch_size": 1
    }
  },
  "17": {
    "_meta": {"title": "비디오 결합"},
    "class_type": "VHS_VideoCombine",
    "inputs": {
      "images": ["51", 0],
      "audio": ["16", 0],
      "frame_rate": 32,
      "loop_count": 0,
      "filename_prefix": "myaniform/lipsync",
      "format": "video/h264-mp4",
      "pingpong": false,
      "save_output": true
    }
  }
}
