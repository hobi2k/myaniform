{
  "1": {
    "_meta": {"title": "레퍼런스 이미지 로드"},
    "class_type": "LoadImage",
    "inputs": {
      "image": "reference_character.png",
      "upload": "image"
    }
  },
  "2": {
    "_meta": {"title": "SDXL 체크포인트"},
    "class_type": "UNETLoader",
    "inputs": {
      "unet_name": "DasiwaIllustriousAnime_v7.safetensors",
      "weight_dtype": "default"
    }
  },
  "3": {
    "_meta": {"title": "CLIP (SDXL)"},
    "class_type": "CLIPLoader",
    "inputs": {
      "clip_name": "clip_g.safetensors",
      "type": "sdxl",
      "device": "default"
    }
  },
  "4": {
    "_meta": {"title": "VAE (SDXL)"},
    "class_type": "VAELoader",
    "inputs": {
      "vae_name": "sdxl_vae.safetensors"
    }
  },
  "5": {
    "_meta": {"title": "IP-Adapter FaceID 모델"},
    "class_type": "IPAdapterModelLoader",
    "inputs": {
      "ipadapter_file": "ip-adapter-faceid-plusv2_sdxl.bin"
    }
  },
  "6": {
    "_meta": {"title": "CLIP Vision"},
    "class_type": "CLIPVisionLoader",
    "inputs": {
      "clip_name": "CLIP-ViT-H-14-laion2B-s32B-b79K.safetensors"
    }
  },
  "7": {
    "_meta": {"title": "IP-Adapter FaceID 주입"},
    "class_type": "IPAdapterFaceID",
    "inputs": {
      "model": ["2", 0],
      "ipadapter": ["5", 0],
      "image": ["1", 0],
      "clip_vision": ["6", 0],
      "weight": 0.8,
      "weight_faceidv2": 1.0,
      "combine_embeds": "concat",
      "start_at": 0.0,
      "end_at": 1.0,
      "embeds_scaling": "V only"
    }
  },
  "8": {
    "_meta": {"title": "프롬프트 (Positive)"},
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["3", 0],
      "text": "1girl, anime style, character sheet, front view, side view, expression sheet, white background, high quality"
    }
  },
  "9": {
    "_meta": {"title": "Negative"},
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["3", 0],
      "text": "worst quality, low quality, blurry, deformed, bad anatomy, watermark"
    }
  },
  "10": {
    "_meta": {"title": "빈 레이턴트"},
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": 1216,
      "height": 832,
      "batch_size": 1
    }
  },
  "11": {
    "_meta": {"title": "KSampler — 캐릭터 클론"},
    "class_type": "KSamplerAdvanced",
    "inputs": {
      "model": ["7", 0],
      "positive": ["8", 0],
      "negative": ["9", 0],
      "latent_image": ["10", 0],
      "add_noise": "enable",
      "noise_seed": 0,
      "control_after_generate": "fixed",
      "steps": 28,
      "cfg": 6.0,
      "sampler_name": "euler_ancestral",
      "scheduler": "karras",
      "start_at_step": 0,
      "end_at_step": 10000,
      "return_with_leftover_noise": "disable"
    }
  },
  "12": {
    "_meta": {"title": "VAE 디코딩"},
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["11", 0],
      "vae": ["4", 0]
    }
  },
  "13": {
    "_meta": {"title": "클론 캐릭터 저장"},
    "class_type": "SaveImage",
    "inputs": {
      "images": ["12", 0],
      "filename_prefix": "myaniform/char_clone"
    }
  }
}
