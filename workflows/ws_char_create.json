{
  "1": {
    "_meta": {"title": "SDXL 체크포인트 (Dasiwa)"},
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "DasiwaIllustriousRealistic_v1.safetensors"
    }
  },
  "2": {
    "_meta": {"title": "캐릭터 / 장면 Positive"},
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["1", 1],
      "text": "1girl, anime style, masterpiece, best quality, detailed"
    }
  },
  "3": {
    "_meta": {"title": "Negative"},
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["1", 1],
      "text": "worst quality, low quality, blurry, deformed, watermark, text"
    }
  },
  "4": {
    "_meta": {"title": "빈 레이턴트 (SDXL 832×1216)"},
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": 832,
      "height": 1216,
      "batch_size": 1
    }
  },
  "5": {
    "_meta": {"title": "KSampler"},
    "class_type": "KSamplerAdvanced",
    "inputs": {
      "model": ["1", 0],
      "positive": ["2", 0],
      "negative": ["3", 0],
      "latent_image": ["4", 0],
      "add_noise": "enable",
      "noise_seed": 0,
      "steps": 25,
      "cfg": 7.0,
      "sampler_name": "euler_ancestral",
      "scheduler": "karras",
      "start_at_step": 0,
      "end_at_step": 10000,
      "return_with_leftover_noise": "disable"
    }
  },
  "6": {
    "_meta": {"title": "VAE Decode"},
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["5", 0],
      "vae": ["1", 2]
    }
  },
  "7": {
    "_meta": {"title": "이미지 저장"},
    "class_type": "SaveImage",
    "inputs": {
      "images": ["6", 0],
      "filename_prefix": "myaniform/keyframe"
    }
  }
}
