{
  "1": {
    "_meta": {"title": "WAN VAE"},
    "class_type": "WanVideoVAELoader",
    "inputs": {
      "model_name": "Wan2_1_VAE_bf16.safetensors",
      "precision": "bf16"
    }
  },
  "2": {
    "_meta": {"title": "WAN T5"},
    "class_type": "LoadWanVideoT5TextEncoder",
    "inputs": {
      "model_name": "umt5-xxl-enc-bf16.safetensors",
      "precision": "bf16",
      "load_device": "offload_device",
      "quantization": "disabled"
    }
  },
  "3": {
    "_meta": {"title": "Text Embeds (pos+neg)"},
    "class_type": "WanVideoTextEncode",
    "inputs": {
      "positive_prompt": "gentle camera push-in, soft anime style motion",
      "negative_prompt": "色调艳丽，过曝，静态，细节模糊不清，字幕，风格，作品，画作，画面，静止，整体发灰，最差质量，低质量，JPEG压缩残留，丑陋的，残缺的，多余的手指，画得不好的手部，画得不好的脸部，畸形的，毁容的，形态畸形的肢体，手指融合，静止不动的画面，杂乱的背景，三条腿，背景人很多，倒着走",
      "t5": ["2", 0],
      "force_offload": true,
      "use_disk_cache": false,
      "device": "gpu"
    }
  },
  "5": {
    "_meta": {"title": "Start 키프레임"},
    "class_type": "LoadImage",
    "inputs": {
      "image": "keyframe.png"
    }
  },
  "7": {
    "_meta": {"title": "End 키프레임"},
    "class_type": "LoadImage",
    "inputs": {
      "image": "keyframe.png"
    }
  },
  "6": {
    "_meta": {"title": "Image Embeds (start→end 이펙트)"},
    "class_type": "WanVideoImageToVideoEncode",
    "inputs": {
      "vae": ["1", 0],
      "start_image": ["5", 0],
      "end_image": ["7", 0],
      "width": 480,
      "height": 832,
      "num_frames": 49,
      "noise_aug_strength": 0.0,
      "start_latent_strength": 1.0,
      "end_latent_strength": 1.0,
      "force_offload": true,
      "tiled_vae": false
    }
  },

  "11": {
    "_meta": {"title": "BlockSwap HIGH (20 blocks)"},
    "class_type": "WanVideoBlockSwap",
    "inputs": {
      "blocks_to_swap": 20,
      "offload_img_emb": false,
      "offload_txt_emb": false,
      "use_non_blocking": true,
      "vace_blocks_to_swap": 0,
      "prefetch_blocks": 0,
      "block_swap_debug": false
    }
  },
  "12": {
    "_meta": {"title": "LoRA HIGH"},
    "class_type": "WanVideoLoraSelectMulti",
    "inputs": {
      "lora_0": "none", "strength_0": 1.0,
      "lora_1": "none", "strength_1": 1.0,
      "lora_2": "none", "strength_2": 1.0,
      "lora_3": "none", "strength_3": 1.0,
      "lora_4": "none", "strength_4": 1.0,
      "low_mem_load": false,
      "merge_loras": false
    }
  },
  "10": {
    "_meta": {"title": "WanVideoModelLoader HIGH"},
    "class_type": "WanVideoModelLoader",
    "inputs": {
      "model": "wan_i2v_high/DasiwaWAN22I2V14BLightspeed_synthseductionHighV9.safetensors",
      "base_precision": "fp16_fast",
      "quantization": "fp8_e4m3fn",
      "load_device": "offload_device",
      "attention_mode": "sageattn",
      "block_swap_args": ["11", 0],
      "lora": ["12", 0]
    }
  },
  "14": {
    "_meta": {"title": "WanVideoSampler HIGH (0→3)"},
    "class_type": "WanVideoSampler",
    "inputs": {
      "model": ["10", 0],
      "image_embeds": ["6", 0],
      "text_embeds": ["3", 0],
      "steps": 6,
      "cfg": 1.0,
      "shift": 8.0,
      "seed": 0,
      "force_offload": true,
      "scheduler": "euler",
      "riflex_freq_index": 0,
      "denoise_strength": 1.0,
      "start_step": 0,
      "end_step": 3
    }
  },

  "21": {
    "_meta": {"title": "BlockSwap LOW (20 blocks)"},
    "class_type": "WanVideoBlockSwap",
    "inputs": {
      "blocks_to_swap": 20,
      "offload_img_emb": false,
      "offload_txt_emb": false,
      "use_non_blocking": true,
      "vace_blocks_to_swap": 0,
      "prefetch_blocks": 0,
      "block_swap_debug": false
    }
  },
  "22": {
    "_meta": {"title": "LoRA LOW"},
    "class_type": "WanVideoLoraSelectMulti",
    "inputs": {
      "lora_0": "none", "strength_0": 1.0,
      "lora_1": "none", "strength_1": 1.0,
      "lora_2": "none", "strength_2": 1.0,
      "lora_3": "none", "strength_3": 1.0,
      "lora_4": "none", "strength_4": 1.0,
      "low_mem_load": false,
      "merge_loras": false
    }
  },
  "20": {
    "_meta": {"title": "WanVideoModelLoader LOW"},
    "class_type": "WanVideoModelLoader",
    "inputs": {
      "model": "wan_i2v_low/DasiwaWAN22I2V14BLightspeed_synthseductionLowV9.safetensors",
      "base_precision": "fp16_fast",
      "quantization": "fp8_e4m3fn",
      "load_device": "offload_device",
      "attention_mode": "sageattn",
      "block_swap_args": ["21", 0],
      "lora": ["22", 0]
    }
  },
  "24": {
    "_meta": {"title": "WanVideoSampler LOW (3→end)"},
    "class_type": "WanVideoSampler",
    "inputs": {
      "model": ["20", 0],
      "image_embeds": ["6", 0],
      "text_embeds": ["3", 0],
      "samples": ["14", 0],
      "steps": 6,
      "cfg": 1.0,
      "shift": 8.0,
      "seed": 0,
      "force_offload": true,
      "scheduler": "euler",
      "riflex_freq_index": 0,
      "denoise_strength": 1.0,
      "start_step": 3,
      "end_step": -1
    }
  },

  "30": {
    "_meta": {"title": "VAE Decode (tiled)"},
    "class_type": "WanVideoDecode",
    "inputs": {
      "vae": ["1", 0],
      "samples": ["24", 0],
      "enable_vae_tiling": true,
      "tile_x": 272,
      "tile_y": 272,
      "tile_stride_x": 144,
      "tile_stride_y": 128
    }
  },
  "31": {
    "_meta": {"title": "ColorMatch (Start 키프레임 기준)"},
    "class_type": "ColorMatch",
    "inputs": {
      "image_ref": ["5", 0],
      "image_target": ["30", 0],
      "method": "mkl",
      "strength": 0.5
    }
  },
  "32": {
    "_meta": {"title": "ImageScaleBy (lanczos, 1x)"},
    "class_type": "ImageScaleBy",
    "inputs": {
      "image": ["31", 0],
      "upscale_method": "lanczos",
      "scale_by": 1.0
    }
  },
  "33": {
    "_meta": {"title": "RIFE 보간 (16→32fps)"},
    "class_type": "RIFE VFI",
    "inputs": {
      "ckpt_name": "rife49.pth",
      "frames": ["32", 0],
      "clear_cache_after_n_frames": 32,
      "multiplier": 2,
      "fast_mode": false,
      "ensemble": true,
      "scale_factor": 1.0,
      "dtype": "float32",
      "torch_compile": false,
      "batch_size": 1
    }
  },

  "40": {
    "_meta": {"title": "MMAudio 모델"},
    "class_type": "MMAudioModelLoader",
    "inputs": {
      "mmaudio_model": "mmaudio_large_44k_v2_fp16.safetensors",
      "base_precision": "fp16"
    }
  },
  "41": {
    "_meta": {"title": "MMAudio Feature Utils"},
    "class_type": "MMAudioFeatureUtilsLoader",
    "inputs": {
      "vae_model": "mmaudio_vae_44k_fp16.safetensors",
      "synchformer_model": "mmaudio_synchformer_fp16.safetensors",
      "clip_model": "apple_DFN5B-CLIP-ViT-H-14-384_fp16.safetensors",
      "mode": "44k",
      "precision": "fp16"
    }
  },
  "42": {
    "_meta": {"title": "이펙트 SFX"},
    "class_type": "MMAudioSampler",
    "inputs": {
      "mmaudio_model": ["40", 0],
      "feature_utils": ["41", 0],
      "images": ["32", 0],
      "duration": 3.0,
      "steps": 25,
      "cfg": 4.5,
      "seed": 0,
      "prompt": "soft ambient effect",
      "negative_prompt": "music, speech, sudden noise",
      "mask_away_clip": false,
      "force_offload": true
    }
  },

  "50": {
    "_meta": {"title": "비디오 결합 (32fps)"},
    "class_type": "VHS_VideoCombine",
    "inputs": {
      "images": ["33", 0],
      "audio": ["42", 0],
      "frame_rate": 32,
      "loop_count": 0,
      "filename_prefix": "myaniform/effect",
      "format": "video/h264-mp4",
      "pix_fmt": "yuv420p",
      "crf": 15,
      "save_metadata": false,
      "trim_to_audio": false,
      "pingpong": false,
      "save_output": true
    }
  }
}
