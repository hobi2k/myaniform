{
  "_comment": "A안 전용 — 생성된 클립들을 ComfyUI 안에서 연결. 클립 수에 맞게 노드를 추가/제거하세요.",

  "1": {
    "_meta": {"title": "Scene 001 로드"},
    "class_type": "VHS_LoadVideo",
    "inputs": {
      "video": "output/scene_001_lipsync.mp4",
      "force_rate": 24,
      "force_size": "Disabled",
      "custom_width": 832,
      "custom_height": 480,
      "frame_load_cap": 0,
      "skip_first_frames": 0,
      "select_every_nth": 1,
      "meta_batch": null,
      "unique_id": 0
    }
  },
  "2": {
    "_meta": {"title": "Scene 002 로드"},
    "class_type": "VHS_LoadVideo",
    "inputs": {
      "video": "output/scene_002_loop.mp4",
      "force_rate": 24,
      "force_size": "Disabled",
      "custom_width": 832,
      "custom_height": 480,
      "frame_load_cap": 0,
      "skip_first_frames": 0,
      "select_every_nth": 1,
      "meta_batch": null,
      "unique_id": 1
    }
  },
  "3": {
    "_meta": {"title": "Scene 003 로드"},
    "class_type": "VHS_LoadVideo",
    "inputs": {
      "video": "output/scene_003_effect.mp4",
      "force_rate": 24,
      "force_size": "Disabled",
      "custom_width": 832,
      "custom_height": 480,
      "frame_load_cap": 0,
      "skip_first_frames": 0,
      "select_every_nth": 1,
      "meta_batch": null,
      "unique_id": 2
    }
  },
  "4": {
    "_meta": {"title": "프레임 배치 통합 (1+2)"},
    "class_type": "ImageBatch",
    "inputs": {
      "image1": ["1", 0],
      "image2": ["2", 0]
    }
  },
  "5": {
    "_meta": {"title": "프레임 배치 통합 (+3)"},
    "class_type": "ImageBatch",
    "inputs": {
      "image1": ["4", 0],
      "image2": ["3", 0]
    }
  },
  "6": {
    "_meta": {"title": "최종 영상 출력"},
    "class_type": "VHS_VideoCombine",
    "inputs": {
      "images": ["5", 0],
      "frame_rate": 24,
      "loop_count": 0,
      "filename_prefix": "final/final",
      "format": "video/h264-mp4",
      "pingpong": false,
      "save_output": true,
      "pix_fmt": "yuv420p",
      "crf": 16,
      "save_metadata": false,
      "trim_to_audio": false
    }
  }
}
