{
  "_meta": {
    "title": "SDXL 고품질 씬 이미지 (Illustrious + 3-pass FaceDetailer)",
    "description": "D:/.../이미지 워크플로우.json 포팅. 30 steps euler_ancestral + body/face/hand FaceDetailer 파이프라인. LoRA 최대 3개. character_refs 는 프롬프트 텍스트로만 주입 (다중 인물 지원)."
  },
  "1": {
    "_meta": {"title": "SDXL Checkpoint"},
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "waiIllustriousSDXL_v160.safetensors"
    }
  },
  "2": {
    "_meta": {"title": "LoRA 1"},
    "class_type": "LoraLoader",
    "inputs": {
      "model": ["1", 0],
      "clip": ["1", 1],
      "lora_name": "None",
      "strength_model": 1.0,
      "strength_clip": 1.0
    }
  },
  "3": {
    "_meta": {"title": "LoRA 2"},
    "class_type": "LoraLoader",
    "inputs": {
      "model": ["2", 0],
      "clip": ["2", 1],
      "lora_name": "None",
      "strength_model": 1.0,
      "strength_clip": 1.0
    }
  },
  "4": {
    "_meta": {"title": "LoRA 3"},
    "class_type": "LoraLoader",
    "inputs": {
      "model": ["3", 0],
      "clip": ["3", 1],
      "lora_name": "None",
      "strength_model": 1.0,
      "strength_clip": 1.0
    }
  },
  "10": {
    "_meta": {"title": "Positive"},
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["4", 1],
      "text": "masterpiece, best quality, highly detailed, 1girl, anime style, sharp focus"
    }
  },
  "11": {
    "_meta": {"title": "Negative"},
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["4", 1],
      "text": "embedding:EasyNegative, embedding:badhandv4, worst quality, bad quality, low quality, lowres, long neck, (logo:1.5), (brand name:1.5), text, letters, watermark"
    }
  },
  "20": {
    "_meta": {"title": "Empty Latent"},
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": 832,
      "height": 1216,
      "batch_size": 1
    }
  },
  "30": {
    "_meta": {"title": "KSampler (30 steps euler_ancestral)"},
    "class_type": "KSampler",
    "inputs": {
      "model": ["4", 0],
      "positive": ["10", 0],
      "negative": ["11", 0],
      "latent_image": ["20", 0],
      "seed": 0,
      "control_after_generate": "randomize",
      "steps": 30,
      "cfg": 5.0,
      "sampler_name": "euler_ancestral",
      "scheduler": "sgm_uniform",
      "denoise": 1.0
    }
  },
  "40": {
    "_meta": {"title": "VAE Decode"},
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["30", 0],
      "vae": ["1", 2]
    }
  },
  "50": {
    "_meta": {"title": "BBox: face_yolov8m"},
    "class_type": "UltralyticsDetectorProvider",
    "inputs": {"model_name": "bbox/face_yolov8m.pt"}
  },
  "51": {
    "_meta": {"title": "BBox: hand_yolov8s"},
    "class_type": "UltralyticsDetectorProvider",
    "inputs": {"model_name": "bbox/hand_yolov8s.pt"}
  },
  "52": {
    "_meta": {"title": "SAM vit_b"},
    "class_type": "SAMLoader",
    "inputs": {
      "model_name": "sam_vit_b_01ec64.pth",
      "device_mode": "AUTO"
    }
  },
  "60": {
    "_meta": {"title": "Face Detailer"},
    "class_type": "FaceDetailer",
    "inputs": {
      "image": ["40", 0],
      "model": ["4", 0],
      "clip": ["4", 1],
      "vae": ["1", 2],
      "positive": ["10", 0],
      "negative": ["11", 0],
      "bbox_detector": ["50", 0],
      "sam_model_opt": ["52", 0],
      "guide_size": 512,
      "guide_size_for": true,
      "max_size": 1536,
      "seed": 0,
      "control_after_generate": "randomize",
      "steps": 10,
      "cfg": 4.5,
      "sampler_name": "euler",
      "scheduler": "sgm_uniform",
      "denoise": 0.25,
      "feather": 5,
      "noise_mask": true,
      "force_inpaint": true,
      "bbox_threshold": 0.5,
      "bbox_dilation": 10,
      "bbox_crop_factor": 3.0,
      "sam_detection_hint": "center-1",
      "sam_dilation": 0,
      "sam_threshold": 0.7,
      "sam_bbox_expansion": 0,
      "sam_mask_hint_threshold": 0.7,
      "sam_mask_hint_use_negative": "False",
      "drop_size": 10,
      "wildcard": "",
      "cycle": 1,
      "inpaint_model": false,
      "noise_mask_feather": 20,
      "tiled_encode": false,
      "tiled_decode": false
    }
  },
  "61": {
    "_meta": {"title": "Hand Detailer"},
    "class_type": "FaceDetailer",
    "inputs": {
      "image": ["60", 0],
      "model": ["4", 0],
      "clip": ["4", 1],
      "vae": ["1", 2],
      "positive": ["10", 0],
      "negative": ["11", 0],
      "bbox_detector": ["51", 0],
      "sam_model_opt": ["52", 0],
      "guide_size": 512,
      "guide_size_for": true,
      "max_size": 1536,
      "seed": 0,
      "control_after_generate": "randomize",
      "steps": 10,
      "cfg": 4.5,
      "sampler_name": "euler",
      "scheduler": "sgm_uniform",
      "denoise": 0.25,
      "feather": 0,
      "noise_mask": true,
      "force_inpaint": true,
      "bbox_threshold": 0.5,
      "bbox_dilation": 10,
      "bbox_crop_factor": 3.0,
      "sam_detection_hint": "center-1",
      "sam_dilation": 0,
      "sam_threshold": 0.69,
      "sam_bbox_expansion": 0,
      "sam_mask_hint_threshold": 0.7,
      "sam_mask_hint_use_negative": "False",
      "drop_size": 10,
      "wildcard": "",
      "cycle": 1,
      "inpaint_model": false,
      "noise_mask_feather": 20,
      "tiled_encode": false,
      "tiled_decode": false
    }
  },
  "70": {
    "_meta": {"title": "Save Image"},
    "class_type": "SaveImage",
    "inputs": {
      "images": ["61", 0],
      "filename_prefix": "myaniform/scene_sdxl"
    }
  }
}
