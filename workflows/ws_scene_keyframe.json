{
  "1": {
    "_meta": {"title": "Qwen Image Edit (GGUF Q5_0)"},
    "class_type": "UnetLoaderGGUF",
    "inputs": {
      "unet_name": "qwen-image-edit-2511-Q5_0.gguf"
    }
  },
  "2": {
    "_meta": {"title": "Qwen 2.5 VL Text Encoder"},
    "class_type": "CLIPLoader",
    "inputs": {
      "clip_name": "qwen_2.5_vl_7b_fp8_scaled.safetensors",
      "type": "qwen_image",
      "device": "default"
    }
  },
  "3": {
    "_meta": {"title": "Qwen Image VAE"},
    "class_type": "VAELoader",
    "inputs": {
      "vae_name": "qwen_image_vae.safetensors"
    }
  },
  "4": {
    "_meta": {"title": "Lightning 4-step distill LoRA"},
    "class_type": "LoraLoader",
    "inputs": {
      "model": ["1", 0],
      "clip": ["2", 0],
      "lora_name": "qwen/Qwen-Image-Edit-2511-Lightning-4steps-V1.0-bf16.safetensors",
      "strength_model": 1.0,
      "strength_clip": 1.0
    }
  },
  "5": {
    "_meta": {"title": "Pose transfer LoRA"},
    "class_type": "LoraLoader",
    "inputs": {
      "model": ["4", 0],
      "clip": ["4", 1],
      "lora_name": "qwen/VNCCS/poser_helper_v2_000004200.safetensors",
      "strength_model": 1.0,
      "strength_clip": 1.0
    }
  },
  "6": {
    "_meta": {"title": "Clothes preserve LoRA"},
    "class_type": "LoraLoader",
    "inputs": {
      "model": ["5", 0],
      "clip": ["5", 1],
      "lora_name": "qwen/VNCCS/ClothesHelperUltimateV1_000005100.safetensors",
      "strength_model": 0.8,
      "strength_clip": 1.0
    }
  },
  "10": {
    "_meta": {"title": "캐릭터 A 레퍼런스"},
    "class_type": "LoadImage",
    "inputs": {
      "image": "character_ref_a.png"
    }
  },
  "11": {
    "_meta": {"title": "캐릭터 B 레퍼런스 (옵션)"},
    "class_type": "LoadImage",
    "inputs": {
      "image": "character_ref_b.png"
    }
  },
  "20": {
    "_meta": {"title": "씬 Positive (다중 레퍼런스)"},
    "class_type": "TextEncodeQwenImageEditPlus",
    "inputs": {
      "clip": ["6", 1],
      "vae": ["3", 0],
      "prompt": "The same character from Picture 1, standing in a softly lit bedroom, looking at the viewer, anime style, detailed face, consistent appearance",
      "image1": ["10", 0],
      "image2": ["11", 0]
    }
  },
  "21": {
    "_meta": {"title": "씬 Negative"},
    "class_type": "TextEncodeQwenImageEditPlus",
    "inputs": {
      "clip": ["6", 1],
      "vae": ["3", 0],
      "prompt": "worst quality, low quality, blurry, deformed, extra limbs, bad anatomy, different character, watermark, text"
    }
  },
  "25": {
    "_meta": {"title": "Qwen 레퍼런스 해상도 빈 latent"},
    "class_type": "EmptyQwenImageLayeredLatentImage",
    "inputs": {
      "width": 832,
      "height": 1216,
      "layers": 3,
      "batch_size": 1
    }
  },
  "30": {
    "_meta": {"title": "KSampler (Lightning 4-step)"},
    "class_type": "KSamplerAdvanced",
    "inputs": {
      "model": ["6", 0],
      "positive": ["20", 0],
      "negative": ["21", 0],
      "latent_image": ["25", 0],
      "add_noise": "enable",
      "noise_seed": 0,
      "control_after_generate": "randomize",
      "steps": 4,
      "cfg": 1.0,
      "sampler_name": "euler",
      "scheduler": "simple",
      "start_at_step": 0,
      "end_at_step": 10000,
      "return_with_leftover_noise": "disable"
    }
  },
  "40": {
    "_meta": {"title": "VAE Decode"},
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["30", 0],
      "vae": ["3", 0]
    }
  },
  "60": {
    "_meta": {"title": "씬 키프레임 저장"},
    "class_type": "SaveImage",
    "inputs": {
      "images": ["40", 0],
      "filename_prefix": "myaniform/scene_keyframe"
    }
  }
}
